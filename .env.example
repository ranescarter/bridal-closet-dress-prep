# Copy to .env.local and fill in. Never commit real secrets.

# Shopify Admin (Client ID + Secret → short-lived access token)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_COLLECTION_HANDLE=gowns-in-store

# Supabase — URL is public; service role is server-only
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Staff dashboard password (server-only)
STAFF_PASSWORD=

# Production hosts (localhost uses the current origin for session links)
NEXT_PUBLIC_ADMIN_ORIGIN=https://admin.mybridalcloset.com
NEXT_PUBLIC_BRIDE_ORIGIN=https://bride.mybridalcloset.com
NEXT_PUBLIC_GUEST_ORIGIN=https://guest.mybridalcloset.com

# Optional: Social Media dashboard origin for /staff/social-media-responses rewrites
# SOCIAL_MEDIA_ORIGIN=https://social-media-dashboard-seven-omega.vercel.app
